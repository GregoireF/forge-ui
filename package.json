{
  "name": "forge-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.1",
  "workspaces": [
    "packages/*",
    "packages/primitives/*",
    "apps/*",
    "e2e"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "bun tooling/dev/index.tsx",
    "dev:react": "bun run --cwd apps/playground-react dev",
    "dev:vue": "bun run --cwd apps/playground-vue dev",
    "dev:nuxt": "bun run --cwd apps/playground-nuxt dev",
    "dev:docs": "bun run --cwd apps/docs dev",
    "test": "turbo run test --filter=!e2e",
    "test:coverage": "turbo run test --filter=!e2e -- --coverage",
    "test:e2e": "bun run --cwd e2e test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "node tooling/scripts/setup-hooks.mjs",
    "size": "bun run tooling/scripts/bundle-size.ts",
    "size:ci": "bun run tooling/scripts/bundle-size.ts --fail-on-threshold",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.0.0",
    "@gregoiref/changeset-config": "^1.0.0",
    "@gregoiref/commitlint-config": "^1.0.0",
    "@gregoiref/tsconfig": "^1.0.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.0.0",
    "happy-dom": "^20.8.9",
    "ink": "^7.1.0",
    "jsdom": "^29.1.1",
    "lefthook": "^1.7.0",
    "react": "^19.2.7",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
