{
  "extends": "../../tooling/tsconfig/vue.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@forge-ui/core": ["../core/src/index.ts"],
      "@forge-ui/dialog": ["../primitives/dialog/src/index.ts"],
      "@forge-ui/field": ["../field/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"],
