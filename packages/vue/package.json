{
  "name": "@forge-ui/vue",
  "version": "0.0.0",
  "private": false,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.ts",
      "import": "./dist/accordion/index.js"
    },
    "./collapsible": {
      "types": "./dist/collapsible/index.d.ts",
      "import": "./dist/collapsible/index.js"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "import": "./dist/tabs/index.js"
    },
    "./progress": {
      "types": "./dist/progress/index.d.ts",
      "import": "./dist/progress/index.js"
    },
    "./radio-group": {
      "types": "./dist/radio-group/index.d.ts",
      "import": "./dist/radio-group/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "import": "./dist/dialog/index.js"
    },
    "./alert-dialog": {
      "types": "./dist/alert-dialog/index.d.ts",
      "import": "./dist/alert-dialog/index.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "import": "./dist/popover/index.js"
    },
    "./select": {
      "types": "./dist/select/index.d.ts",
      "import": "./dist/select/index.js"
    },
    "./combobox": {
      "types": "./dist/combobox/index.d.ts",
      "import": "./dist/combobox/index.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox/index.d.ts",
      "import": "./dist/checkbox/index.js"
    },
    "./switch": {
      "types": "./dist/switch/index.d.ts",
      "import": "./dist/switch/index.js"
    },
    "./tooltip": {
      "types": "./dist/tooltip/index.d.ts",
      "import": "./dist/tooltip/index.js"
    },
    "./hover-card": {
      "types": "./dist/hover-card/index.d.ts",
      "import": "./dist/hover-card/index.js"
    },
    "./field": {
      "types": "./dist/field/index.d.ts",
      "import": "./dist/field/index.js"
    },
    "./slider": {
      "types": "./dist/slider/index.d.ts",
      "import": "./dist/slider/index.js"
    },
    "./tags-input": {
      "types": "./dist/tags-input/index.d.ts",
      "import": "./dist/tags-input/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run ../../tooling/scripts/build.ts",
    "dev": "tsc --watch --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "dependencies": {
    "@forge-ui/accordion": "workspace:*",
    "@forge-ui/collapsible": "workspace:*",
    "@forge-ui/progress": "workspace:*",
    "@forge-ui/radio-group": "workspace:*",
    "@forge-ui/slider": "workspace:*",
    "@forge-ui/tabs": "workspace:*",
    "@forge-ui/alert-dialog": "workspace:*",
    "@forge-ui/checkbox": "workspace:*",
    "@forge-ui/combobox": "workspace:*",
    "@forge-ui/core": "workspace:*",
    "@forge-ui/dialog": "workspace:*",
    "@forge-ui/field": "workspace:*",
    "@forge-ui/popover": "workspace:*",
    "@forge-ui/select": "workspace:*",
    "@forge-ui/switch": "workspace:*",
    "@forge-ui/hover-card": "workspace:*",
    "@forge-ui/tags-input": "workspace:*",
    "@forge-ui/tooltip": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "*",
    "vue": "^3.5.0"
  }
}
